  border-style: solid;
  border-color: rgba(213, 204, 190, 0.8);
}

.room-title {
  flex: 1;
  padding-right: 14rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.room-mode {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: $app-primary;
}

.room-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: $app-muted;
}

.record-card {
  margin-bottom: 16rpx;
  padding-top: 12rpx;
  padding-bottom: 18rpx;
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: rgba(213, 204, 190, 0.7);
}

.record-actions {
  flex-direction: row;
  justify-content: flex-start;
  margin-top: 14rpx;
}

.record-action {
  margin-right: 14rpx;
  align-items: center;
  justify-content: center;
}

.tip-row {
  flex-direction: row;
  align-items: flex-start;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  margin-right: 14rpx;
  border-radius: 6rpx;
  background-color: $app-primary;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.65;
  color: $app-muted;
}
</style>
