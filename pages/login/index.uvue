  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: $app-muted;
}

.auth-heading {
  margin-top: 14rpx;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: $app-text;
}

.auth-description {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: $app-muted;
}

.mode-row {
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.auth-mode-pill {
  margin-right: 12rpx;
}

.auth-field {
  margin-top: 24rpx;
}

.auth-label {
  font-size: 22rpx;
  font-weight: 600;
  color: $app-text;
}

.auth-inline-head {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.field-toggle {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.field-toggle-text {
  font-size: 22rpx;
  color: $app-primary;
}

.auth-input-shell {
  margin-top: 12rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  border-radius: 22rpx;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(31, 75, 78, 0.1);
  background-color: #ffffff;
}

.auth-input-shell--error {
  border-color: rgba(165, 109, 66, 0.48);
  background-color: rgba(165, 109, 66, 0.04);
}

.auth-input {
  height: 92rpx;
  font-size: 28rpx;
  color: $app-text;
}

.auth-error-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background-color: rgba(165, 109, 66, 0.08);
}

.auth-error-text {
  font-size: 22rpx;
  line-height: 1.5;
  color: $app-warning;
}

.auth-submit {
  margin-top: 26rpx;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
}

.auth-submit--disabled {
  opacity: 0.7;
}

.auth-actions {
  flex-direction: row;
  justify-content: space-between;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.auth-action {
  width: 31%;
  align-items: center;
  justify-content: center;
}

.login-note {
  padding-top: 24rpx;
  background-color: rgba(247, 242, 234, 0.9);
}

.wechat-card {
  padding-top: 24rpx;
