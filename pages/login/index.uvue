}

.auth-submit--disabled {
  opacity: 0.7;
}

.auth-actions {
  flex-direction: row;
  justify-content: space-between;
  margin-top: 16rpx;
}

.auth-action {
  width: 48%;
  align-items: center;
  justify-content: center;
}

.login-note {
  padding-top: 24rpx;
  background-color: rgba(247, 242, 234, 0.9);
}

.login-note-title {
  font-size: 28rpx;
