  margin-top: 16rpx;
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 700;
  color: $app-text;
  font-family: 'Georgia', 'Times New Roman', serif;
}

.album-card {
  padding-top: 10rpx;
  padding-bottom: 18rpx;
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: rgba(213, 204, 190, 0.7);
}

.album-title {
  flex: 1;
  padding-right: 14rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.album-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: $app-muted;
}

.album-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: $app-text;
}

.album-tags {
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.album-owner-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: $app-muted;
}

.album-tag {
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background-color: rgba(31, 75, 78, 0.06);
}

.album-tag-text {
  font-size: 22rpx;
  color: $app-primary;
}

.action-row {
  flex-direction: row;
  justify-content: space-between;
}

.action-button {
  width: 48%;
  align-items: center;
  justify-content: center;
}

.album-action-row {
  margin-top: 16rpx;
  align-items: center;
}

.album-action {
  width: 30%;
  align-items: center;
  justify-content: center;
}

.action-toggle {
  width: 34%;
  align-items: center;
  justify-content: center;
}
</style>
