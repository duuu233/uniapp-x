  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.summary-box {
  width: 31%;
  padding: 24rpx 18rpx;
  border-radius: 24rpx;
  background-color: $app-panel;
  border-width: 1px;
  border-style: solid;
  border-color: $app-border;
  box-shadow: $app-shadow-soft;
}

