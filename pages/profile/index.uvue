  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.tag-chip {
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background-color: rgba(31, 75, 78, 0.06);
}

.tag-chip-text {
  font-size: 22rpx;
  color: $app-primary;
}

.action-row {
  flex-direction: row;
  justify-content: space-between;
}

.action-button {
  width: 48%;
  align-items: center;
}

.profile-form-card {
  margin-bottom: 20rpx;
}

.auth-field {
  margin-top: 18rpx;
}

.auth-label {
  font-size: 22rpx;
  font-weight: 600;
  color: $app-text;
}

.auth-inline-head {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.field-toggle {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.field-toggle-text {
  font-size: 22rpx;
  color: $app-primary;
}

.auth-input-shell {
  margin-top: 12rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  border-radius: 22rpx;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(31, 75, 78, 0.1);
  background-color: #ffffff;
}

.auth-input {
  height: 88rpx;
  font-size: 28rpx;
  color: $app-text;
}

.helper-list {
  margin-top: 20rpx;
}

.helper-row {
  flex-direction: row;
  align-items: flex-start;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.helper-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  margin-right: 14rpx;
  border-radius: 6rpx;
  background-color: $app-primary;
}

.helper-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.6;
  color: $app-muted;
}
</style>
