  margin-top: 12rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  border-radius: 22rpx;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(31, 75, 78, 0.1);
  background-color: #ffffff;
}

.auth-input {
  height: 88rpx;
  font-size: 28rpx;
  color: $app-text;
}

.permission-row {
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.permission-pill {
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.action-row {
  flex-direction: row;
  justify-content: space-between;
  margin-top: 10rpx;
}

.action-button {
  width: 48%;
  align-items: center;
  justify-content: center;
}

.device-row {
  padding-top: 10rpx;
  padding-bottom: 18rpx;
  border-bottom-width: 1px;
  border-bottom-style: solid;
  border-bottom-color: rgba(213, 204, 190, 0.7);
}

.device-name {
  flex: 1;
  padding-right: 16rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.device-location {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: $app-muted;
}

.device-meta {
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.device-meta-text,
.device-meta-divider {
  font-size: 22rpx;
  color: $app-muted;
}

.device-meta-divider {
  margin-left: 8rpx;
  margin-right: 8rpx;
}

.device-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: $app-muted;
}

.device-actions {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.action-pill {
  align-items: center;
  justify-content: center;
}

.device-action-button {
  width: 34%;
  align-items: center;
  justify-content: center;
}
</style>
