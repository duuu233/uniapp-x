import { ROUTES } from '@/src/constants/routes.uts'
import { getLocale } from '@/src/i18n/index.uts'
import { getMockState } from '@/src/mock/state.uts'
import { DeviceCard, HomeDashboard } from '@/src/types/models.uts'

function toDeviceCards(count : number = 3) : Array<DeviceCard> {
  const state = getMockState()
  const devices = [] as Array<DeviceCard>
  const maxCount = Math.min(count, state.devices.length)
  for (let i = 0; i < maxCount; i++) {
    const item = state.devices[i]
    devices.push({
      id: item.id,
      name: item.name,
      location: item.location,
      status: item.status,
      statusTone: item.statusTone,
      connection: item.connection,
      battery: item.battery,
      updatedAt: item.updatedAt,
    })
  }
  return devices
}

export function getHomeDashboardMock() : HomeDashboard {
  const state = getMockState()
  const locale = getLocale()
  const onlineCount = state.devices.filter((item) => item.statusTone == 'success' || item.statusTone == 'primary').length
  const pendingAlbumCount = state.albums.filter((item) => item.statusTone == 'warning').length
  const permissionIssueCount = state.devices.filter((item) => item.statusTone == 'warning').length

  if (locale == 'en-US') {
    return {
      greeting: 'Home execution flow is ready',
      subtitle: 'Capture, album selection, device switching and cast confirmation are now wired as mock operational steps on top of the dashboard.',
      metrics: [
        { label: 'Online Devices', value: onlineCount.toString(), delta: 'Live', note: 'Includes devices with active or primary connection', tone: 'primary' },
        { label: 'Pending Albums', value: pendingAlbumCount.toString(), delta: 'Need cast', note: 'Recent records waiting for cast or review', tone: 'warning' },
        { label: 'Cast Records', value: state.castRecords.length.toString(), delta: 'History', note: 'Can be retried or deleted in screen control', tone: 'success' },
        { label: 'Access Issues', value: permissionIssueCount.toString(), delta: 'Check now', note: 'Pending access should be resolved before casting', tone: 'neutral' },
      ],
      quickEntries: [
        { title: 'My Album', subtitle: 'Delete your own photos or cast one selected image', badge: state.albums.length.toString() + ' items', route: ROUTES.ALBUM, tone: 'primary' },
        { title: 'Bind Device', subtitle: 'Use QR, Bluetooth or manual SN entry', badge: '3 methods', route: ROUTES.DEVICE_BIND, tone: 'success' },
        { title: 'My Devices', subtitle: 'Rename, connect, clear memory and switch roles', badge: state.devices.length.toString() + ' devices', route: ROUTES.DEVICE_LIST, tone: 'neutral' },
        { title: 'Permissions', subtitle: 'Check camera, album, location and Bluetooth access', badge: permissionIssueCount.toString() + ' pending', route: ROUTES.PERMISSIONS, tone: 'warning' },
      ],
      workflow: [
        { title: 'Capture Or Pick Image', description: 'Choose between mock camera capture and album selection before entering the cast flow.', statusText: 'Ready', statusTone: 'success' },
        { title: 'Select Device', description: 'Switch the connected device before pushing images to the frame.', statusText: 'Interactive', statusTone: 'primary' },
        { title: 'Preview And Confirm', description: 'Preview record metadata and confirm the cast target before submission.', statusText: 'Required', statusTone: 'warning' },
        { title: 'Record Management', description: 'Successful and failed cast records are collected in screen control for retry or cleanup.', statusText: 'Stable', statusTone: 'success' },
      ],
      devices: toDeviceCards(3),
      notices: [
        'The home page now carries an executable mock cast flow instead of acting as a pure dashboard.',
        'Album, device and cast actions share the same in-memory state, so cross-page updates stay consistent.',
        'Real device APIs can later replace the current mock actions without changing the page structure.',
      ],
    }
  }

  if (locale == 'ja-JP') {
    return {
      greeting: 'ホーム実行フローの準備が整いました',
      subtitle: '撮影、アルバム選択、端末切替、投屏確認を、ダッシュボード上の mock 実行ステップとして接続しました。',
      metrics: [
        { label: '在线设备', value: onlineCount.toString(), delta: '实时', note: '成功 / 主连接状态の端末を含みます', tone: 'primary' },
        { label: '待投屏相册', value: pendingAlbumCount.toString(), delta: '要処理', note: '投屏または審査待ちの最近記録', tone: 'warning' },
        { label: '投屏记录', value: state.castRecords.length.toString(), delta: '履歴', note: '投屏管理で再試行 / 削除できます', tone: 'success' },
        { label: '权限异常', value: permissionIssueCount.toString(), delta: '確認', note: '投屏前に解消が必要です', tone: 'neutral' },
      ],
      quickEntries: [
        { title: 'マイアルバム', subtitle: '自分の写真削除や単枚投屏を行えます。', badge: state.albums.length.toString() + ' 件', route: ROUTES.ALBUM, tone: 'primary' },
        { title: 'デバイス登録', subtitle: 'QR、Bluetooth、SN 手動入力に対応します。', badge: '3 方式', route: ROUTES.DEVICE_BIND, tone: 'success' },
        { title: 'マイデバイス', subtitle: '名称編集、接続切替、一键清空、権限変更に対応します。', badge: state.devices.length.toString() + ' 台', route: ROUTES.DEVICE_LIST, tone: 'neutral' },
        { title: '権限センター', subtitle: '相机、相册、定位、Bluetooth を確認します。', badge: permissionIssueCount.toString() + ' 件', route: ROUTES.PERMISSIONS, tone: 'warning' },
      ],
      workflow: [
        { title: '图片取得', description: 'mock 拍照または相册選択から投屏フローを開始します。', statusText: '準備完了', statusTone: 'success' },
        { title: '设备选择', description: '当前连接端末を切り替えて投屏先を決めます。', statusText: '操作中', statusTone: 'primary' },
        { title: '预览确认', description: '图片情報を確認して投屏先を確定します。', statusText: '必須', statusTone: 'warning' },
        { title: '记录管理', description: '成功 / 失败投屏は投屏管理へ集約されます。', statusText: '安定', statusTone: 'success' },
      ],
      devices: toDeviceCards(3),
      notices: [
        'ホームは純粋な看板ページではなく、実行型 mock フローを持つ入口に変わりました。',
        'アルバム、端末、投屏操作は同じ内存状態を共有し、ページ間更新が揃います。',
        '今後は実デバイス API へ差し替えてもページ構造は維持できます。',
