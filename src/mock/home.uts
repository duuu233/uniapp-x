    greeting: '首页执行流已就绪',
    subtitle: '拍照、相册选择、设备切换和投屏确认已从单纯展示升级为可执行的 mock 业务流程。',
    metrics: [
      { label: '在线设备', value: onlineCount.toString(), delta: '实时', note: '包含连接正常和主连接状态设备', tone: 'primary' },
      { label: '待投屏相册', value: pendingAlbumCount.toString(), delta: '待处理', note: '最近上传且待投屏 / 待审核记录', tone: 'warning' },
      { label: '投屏记录', value: state.castRecords.length.toString(), delta: '历史', note: '可在投屏管理中重试或删除', tone: 'success' },
      { label: '权限异常', value: permissionIssueCount.toString(), delta: '需确认', note: '投屏前建议先处理待授权设备', tone: 'neutral' },
    ],
    quickEntries: [
      { title: '我的相册', subtitle: '支持批量删除自己上传的照片和单张投屏', badge: state.albums.length.toString() + ' 张', route: ROUTES.ALBUM, tone: 'primary' },
      { title: '绑定设备', subtitle: '支持扫码、蓝牙和 SN 手动录入', badge: '3 种方式', route: ROUTES.DEVICE_BIND, tone: 'success' },
      { title: '我的设备', subtitle: '支持重命名、连接切换、一键清空和权限调整', badge: state.devices.length.toString() + ' 台', route: ROUTES.DEVICE_LIST, tone: 'neutral' },
      { title: '权限中心', subtitle: '集中检查相机、相册、定位和蓝牙权限', badge: permissionIssueCount.toString() + ' 项', route: ROUTES.PERMISSIONS, tone: 'warning' },
    ],
    workflow: [
      { title: '拍照 / 选图', description: '从 mock 拍照或相册选择开始，生成新的待投屏记录。', statusText: '已就绪', statusTone: 'success' },
      { title: '设备选择', description: '可切换当前连接设备，确定本次投屏目标。', statusText: '进行中', statusTone: 'primary' },
      { title: '预览确认', description: '确认图片信息、设备名称和相框存储状态后再提交。', statusText: '必选', statusTone: 'warning' },
      { title: '记录归档', description: '投屏成功或失败后，统一进入投屏管理页维护。', statusText: '稳定', statusTone: 'success' },
    ],
    devices: toDeviceCards(3),
    notices: [
      '首页不再只是仪表盘，而是承载拍照、选图、设备选择和确认投屏的执行入口。',
      '相册、设备、投屏操作共享同一份内存状态，跨页面更新保持一致。',
      '后续替换真实设备 API 时，可直接复用当前页面结构与服务接口。',
    ],
  }
}
