function createInitialState() : MockAppState {
  const profile = createInitialProfile()
  return {
    auth: {
      isLoggedIn: true,
      email: profile.email,
      password: 'clear123',
      loginCode: '246810',
      registerCode: '135790',
    },
    profile,
    albums: createInitialAlbums(),
    devices: createInitialDevices(),
    rooms: createInitialRooms(),
    castRecords: createInitialCastRecords(),
    settings: {
      notification: true,
      autoSync: true,
      screenProtect: true,
      biometric: false,
    },
    guideSections: createInitialGuideSections(),
  }
}

export function getMockState() : MockAppState {
  if (mockState == null) {
    mockState = createInitialState()
  }
  return mockState!
}

export function resetMockState() : void {
  mockState = createInitialState()
}

export function issueVerificationCode(kind : string) : string {
  const state = getMockState()
  const code = kind == 'register' ? '135790' : '246810'
  if (kind == 'register') {
    state.auth.registerCode = code
  } else {
    state.auth.loginCode = code
  }
  return code
}

export function markLoggedIn(email : string, password : string) : void {
  const state = getMockState()
  state.auth.isLoggedIn = true
  state.auth.email = email
  state.auth.password = password
  state.profile.email = email
}

export function markLoggedOut() : void {
  const state = getMockState()
  state.auth.isLoggedIn = false
}

export function createAlbumRecord(title : string, sourceTag : string, deviceName : string) : AlbumItem {
  const record : AlbumItem = {
    id: nextId('album'),
    title,
    capturedAt: createTimeLabel(),
    deviceName,
    status: '待投屏',
    statusTone: 'warning',
    summary: '已加入我的相册，等待选择设备后发起投屏。',
    tags: [sourceTag, '新记录'],
    uploadedByCurrentUser: true,
  }
  return record
}

export function createCastRecord(title : string, deviceName : string, tone : Tone, summary : string, status : string) : CastRecord {
  return {
    id: nextId('cast'),
    title,
    deviceName,
    status,
    statusTone: tone,
    createdAt: createTimeLabel(),
    summary,
  }
}
