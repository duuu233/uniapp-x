type MockAuthState = {
  isLoggedIn: boolean
  email: string
  password: string
  loginCode: string
  registerCode: string
}

type MockSettingsFlags = {
  notification: boolean
  autoSync: boolean
  screenProtect: boolean
  biometric: boolean
}

type MockAppState = {
  auth: MockAuthState
  profile: ProfileFormData
  albums: Array<AlbumItem>
  devices: Array<ManagedDevice>
  rooms: Array<ScreenRoom>
  castRecords: Array<CastRecord>
  settings: MockSettingsFlags
  guideSections: Array<GuideSection>
}

let mockState : MockAppState | null = null
let idSeed = 100

function nextId(prefix : string) : string {
  idSeed += 1
  return prefix + '-' + idSeed.toString()
}

export function createTimeLabel(minutesAgo : number = 0) : string {
  const locale = getLocale()
  if (locale == 'en-US') {
    if (minutesAgo <= 0) {
      return 'Just now'
    }
    if (minutesAgo < 60) {
      return minutesAgo.toString() + ' minutes ago'
    }
    return Math.floor(minutesAgo / 60).toString() + ' hours ago'
  }

  if (locale == 'ja-JP') {
    if (minutesAgo <= 0) {
      return 'たった今'
    }
    if (minutesAgo < 60) {
      return minutesAgo.toString() + ' 分前'
    }
    return Math.floor(minutesAgo / 60).toString() + ' 時間前'
  }

  if (minutesAgo <= 0) {
    return '刚刚'
  }
  if (minutesAgo < 60) {
    return minutesAgo.toString() + ' 分钟前'
  }
  return Math.floor(minutesAgo / 60).toString() + ' 小时前'
}

