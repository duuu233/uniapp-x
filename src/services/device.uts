import { getBindPageDataMock, getDevicePageDataMock } from '@/src/mock/device.uts'
import { createTimeLabel, getMockState } from '@/src/mock/state.uts'
import { request } from '@/src/network/http.uts'
import { BindPageData, DevicePageData } from '@/src/types/models.uts'

export function fetchBindPageData(): Promise<BindPageData> {
  return request<BindPageData>({
    path: '/devices/bind/options',
    method: 'GET',
    mockData: getBindPageDataMock(),
  })
}

export function fetchDevicePageData(): Promise<DevicePageData> {
  return request<DevicePageData>({
    path: '/devices',
    method: 'GET',
    mockData: getDevicePageDataMock(),
  })
}

export function bindDeviceByScan(): Promise<string> {
  return new Promise<string>((resolve) => {
    const state = getMockState()
    setTimeout(() => {
      state.devices.push({
        id: 'device-scan-' + Date.now().toString(),
        name: '扫码接入设备',
        location: '新接入设备区',
        status: '在线',
        statusTone: 'success',
        connection: '扫码绑定 / Wi-Fi',
        battery: '外接电源',
        updatedAt: createTimeLabel(),
        ownerName: state.profile.displayName,
        permissionLabel: '所有者',
        serialNumber: 'SCAN-' + Date.now().toString().substring(7),
        connected: false,
        carouselEnabled: false,
        memoryLabel: '剩余 56%',
        typeLabel: '新接入设备',
        canReuseSn: true,
      })
      resolve('已完成扫码绑定，可前往我的设备查看')
    }, 260)
  })
}

