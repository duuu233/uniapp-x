export function bindDeviceManually(serialNumber: string, deviceName: string): Promise<string> {
  return new Promise<string>((resolve, reject) => {
    if (serialNumber.trim().length < 4) {
      reject('SN 码至少 4 位')
      return
    }
    if (deviceName.trim().length < 2) {
      reject('设备名称至少 2 个字符')
      return
    }

    const state = getMockState()
    setTimeout(() => {
      state.devices.push({
        id: 'device-manual-' + Date.now().toString(),
        name: deviceName.trim(),
        location: '手动录入设备区',
        status: '待授权',
        statusTone: 'warning',
        connection: '手动录入 / 待激活',
        battery: '未知',
        updatedAt: createTimeLabel(),
        ownerName: state.profile.displayName,
        permissionLabel: '所有者',
        serialNumber: serialNumber.trim(),
        connected: false,
        carouselEnabled: false,
        memoryLabel: '首次接入待检测',
        typeLabel: '自定义设备',
        canReuseSn: true,
      })
      resolve('已完成手动录入绑定')
    }, 260)
  })
}

export function connectDevice(deviceId: string): Promise<DevicePageData> {
  return new Promise<DevicePageData>((resolve, reject) => {
    const state = getMockState()
    const target = state.devices.find((item) => item.id == deviceId)
    if (target == null) {
      reject('设备不存在')
      return
    }

    setTimeout(() => {
      for (const device of state.devices) {
        device.connected = device.id == deviceId
        if (device.connected) {
          device.updatedAt = createTimeLabel()
        }
      }
      resolve(getDevicePageDataMock())
    }, 180)
  })
}

export function renameDevice(deviceId: string, nextName: string): Promise<DevicePageData> {
  return new Promise<DevicePageData>((resolve, reject) => {
    if (nextName.trim().length < 2) {
      reject('设备名称至少 2 个字符')
      return
    }

    const state = getMockState()
    const target = state.devices.find((item) => item.id == deviceId)
    if (target == null) {
      reject('设备不存在')
      return
    }

    setTimeout(() => {
      target.name = nextName.trim()
      target.updatedAt = createTimeLabel()
      resolve(getDevicePageDataMock())
    }, 180)
  })
}

