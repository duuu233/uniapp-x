export function updateDeviceSn(deviceId: string, serialNumber: string): Promise<DevicePageData> {
  return new Promise<DevicePageData>((resolve, reject) => {
    if (serialNumber.trim().length < 4) {
      reject('SN 码至少 4 位')
      return
    }

    const state = getMockState()
    const target = state.devices.find((item) => item.id == deviceId)
    if (target == null) {
      reject('设备不存在')
      return
    }

    setTimeout(() => {
      target.serialNumber = serialNumber.trim()
      target.updatedAt = createTimeLabel()
      resolve(getDevicePageDataMock())
    }, 180)
  })
}

export function clearDeviceMemory(deviceId: string): Promise<DevicePageData> {
  return new Promise<DevicePageData>((resolve, reject) => {
    const state = getMockState()
    const target = state.devices.find((item) => item.id == deviceId)
    if (target == null) {
      reject('设备不存在')
      return
    }
    if (target.permissionLabel != '所有者') {
      reject('仅设备所有者可执行一键清空')
      return
    }

    setTimeout(() => {
      target.memoryLabel = '已一键清空，剩余 100%'
      target.updatedAt = createTimeLabel()
      resolve(getDevicePageDataMock())
    }, 180)
  })
}

export function toggleDeviceCarousel(deviceId: string): Promise<DevicePageData> {
  return new Promise<DevicePageData>((resolve, reject) => {
    const state = getMockState()
    const target = state.devices.find((item) => item.id == deviceId)
    if (target == null) {
      reject('设备不存在')
      return
    }

    setTimeout(() => {
      target.carouselEnabled = !target.carouselEnabled
      target.updatedAt = createTimeLabel()
      resolve(getDevicePageDataMock())
    }, 180)
  })
}
