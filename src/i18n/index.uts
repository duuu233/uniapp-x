        suggestionTitle: '実装案',
        loadError: '権限データの読み込みに失敗しました',
      },
      settings: {
        kicker: '設定',
        title: '設定',
        heroSubtitle: 'バージョン {version} ・ 最終同期 {lastSync}',
        language: {
          title: '言語',
          subtitle: 'アプリの表示言語を選択します。選択結果は自動的に保存されます。',
          current: '現在',
          changed: '{language} に切り替えました',
        },
        suggestionTitle: '実装提案',
        suggestionSubtitle: '設定項目はバックエンドの設定センターで管理し、ローカルキャッシュをフォールバックにすると、各プラットフォームでの手動差分を防げます。',
        loadError: '設定の読み込みに失敗しました',
      },
    },
  },
}

const i18n = createI18n({
  locale: resolveInitialLocale(),
  fallbackLocale: DEFAULT_LOCALE,
  messages,
  tabBars: {
    'zh-CN': ['首页', '我的'],
    'en-US': ['Home', 'Mine'],
    'ja-JP': ['ホーム', 'マイ'],
  },
})

export default i18n

export function t(key : string, values : any | null = null, locale : string | null = null) : string {
  return i18n.global.t(key, values, locale)
}

export function getLocale() : AppLocale {
  return normalizeLocale(i18n.global.locale.value)
}

export function setLocale(locale : string) : AppLocale {
  const nextLocale = normalizeLocale(locale)
  i18n.global.locale.value = nextLocale
  return nextLocale
}

export function isLocale(locale : string) : boolean {
  return getLocale() == normalizeLocale(locale)
}

export function getLanguageLabel(locale : string) : string {
  const currentLocale = normalizeLocale(locale)
  if (currentLocale == 'en-US') {
    return 'English'
  }

  if (currentLocale == 'ja-JP') {
    return '日本語'
  }

  return '简体中文'
}

export function applyPageTitle(key : string) : void {
  uni.setNavigationBarTitle({
    title: t(key),
  })
}
