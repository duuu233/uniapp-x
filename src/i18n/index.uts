import { createI18n } from '@/uni_modules/lime-i18n/index.uts'

export type AppLocale = 'zh-CN' | 'en-US' | 'ja-JP'

const DEFAULT_LOCALE : AppLocale = 'zh-CN'

function normalizeLocale(locale : string | null = null) : AppLocale {
  const value = locale == null ? '' : locale.toLowerCase()

  if (value.indexOf('en') == 0) {
    return 'en-US'
  }

  if (value.indexOf('ja') == 0) {
    return 'ja-JP'
  }

  return 'zh-CN'
}

function resolveInitialLocale() : AppLocale {
  const cachedLocale = uni.getStorageSync('uVueI18nLocale')
  if (typeof cachedLocale == 'string' && cachedLocale.length > 0) {
    return normalizeLocale(cachedLocale)
  }

  return DEFAULT_LOCALE
}

